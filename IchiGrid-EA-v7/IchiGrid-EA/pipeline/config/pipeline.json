      "L3": {"code": "Include/L3", "data": "Data/L3", "resources": "Resources/L3"}
    },
    "routing": {
      "_comment": "Extension → type de dossier cible",
      ".mqh": "code",
      ".mq5": "code",
      ".csv": "data",
      ".json": "data",
      ".dat": "data",
      ".png": "resources",
      ".log": "resources",
      ".md": "resources",
      ".txt": "resources",
      ".zip": "resources"
    },
