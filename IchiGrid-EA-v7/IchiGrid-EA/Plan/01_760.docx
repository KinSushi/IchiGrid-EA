   LOCK_RANGE_PROLONGE,

   LOCK_SPREAD_EXCESSIF,

   LOCK_GRILLE_SATUREE,

   LOCK_SL_SERIEUX,

   LOCK_VOLATILITE_PERDUE,

   LOCK_INCOHERENCE_SIGNAL

};

