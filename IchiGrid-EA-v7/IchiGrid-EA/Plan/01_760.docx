  "time_range": "14:00–17:00",

  "style": "SWING",

  "winrate": 52.3,

  "setup": "Breakout_Kumo"

}

Après :

"ZONE_US_SCALP_1": {

  "time_range": "14:00–15:30",

  "style": "SCALPING",

  "setup": "Rejet_Kijun"

},

"ZONE_US_SWING_2": {

