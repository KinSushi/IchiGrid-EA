**🧩**** 480.7. Intégration dans OnTick()**

if (EnableHolisticDecisionEngine) {

   double dsi = ComputeDSI(fusion);

   if (dsi >= MinDSIToTrade) ExecuteTrade();

   else if (dsi >= 65) TrackAsObservedSignal();

   else Print("❌ DSI trop faible : trade bloqué");

}

