Parfait. Voici la **conception ultra détaillée du module TPSLManager.mqh** pour gérer les **TP/SL virtuels intelligents**, y compris leur **affichage graphique**, leur **logique conditionnelle**, leur **trailing dynamique**, leur **fusion Overlap** et leur **sécurité (anti-erreur)** — avec une architecture MQL5 conforme, robuste, extensible et compatible avec les grilles.

**🎯**** MODULE TPSLManager.mqh — TAKE PROFIT / STOP LOSS VIRTUELS INTELLIGENTS**

**📦**** 1. OBJECTIFS DU MODULE**

| **Fonctionnalité** | **Description** |
| --- | --- |
| 🎯 TP virtuel | Calculé côté EA, pas visible par le broker |
| 🛡️ SL virtuel | Idem, placé à distance stratégique (Kijun, ATR, etc.) |
| 🔁 Trailing TP | TP déplacé dynamiquement si la tendance continue |
| 🔂 Overlap TP | Plusieurs ordres avec un TP commun si convergence |
| 👁️ Affichage graphique | Lignes TP/SL visibles avec couleur, label et type |
| 🚫 SL anti-erreur | Empêche un SL trop proche du prix |

**🧩**** 2. STRUCTURE DU FICHIER TPSLManager.mqh**

**🔷**** 2.1. Variables globales**

// Paramètres externes

input int    VirtualTPPoints = 27;

input bool   UseTPOverlap    = true;

input int    OverlapAfterXOrders = 3;

input bool   EnableTrailingTP = true;

input double TP_Trail_ATR_Mult = 1.5;

input bool   EnableVirtualSL = true;

input double SL_ATR_Mult = 2.0;

// Couleurs d'affichage

color TPColor = clrLimeGreen;

color SLColor = clrRed;

**🔷**** 2.2. Structuration des niveaux**

struct VirtualTarget {

   ulong ticket;

   double price_tp;

   double price_sl;

   datetime lastUpdate;

   bool trailingActive;

};

CArrayObj *TargetsArray;

**⚙️**** 3. FONCTIONS PRINCIPALES DU MODULE**

**🛠️**** 3.1. InitTPSL()**

void InitTPSL() {

   if (TargetsArray == NULL) TargetsArray = new CArrayObj;

}

**🧹**** 3.2. DeinitTPSL()**

void DeinitTPSL() {

   if (TargetsArray != NULL) {

      TargetsArray.Clear();

      delete TargetsArray;

   }

}

**🎯**** 3.3. AssignTP_SL(ulong ticket)**

Attribue TP/SL virtuels à un ordre donné :

void AssignTP_SL(ulong ticket) {

   double openPrice = OrderOpenPrice(ticket);

   double atr = iATR(_Symbol, PERIOD_CURRENT, 14, 0);

   double tpDistance = VirtualTPPoints * _Point;

   double slDistance = atr * SL_ATR_Mult;

   double tp = (OrderType(ticket) == ORDER_TYPE_BUY) ? openPrice + tpDistance : openPrice - tpDistance;

   double sl = (OrderType(ticket) == ORDER_TYPE_BUY) ? openPrice - slDistance : openPrice + slDistance;

   if (MathAbs(sl - SymbolInfoDouble(_Symbol, SYMBOL_BID)) < 5 * _Point) return; // sécurité anti-erreur

   VirtualTarget *vt = new VirtualTarget;

   vt.ticket = ticket;

   vt.price_tp = tp;

   vt.price_sl = EnableVirtualSL ? sl : 0.0;

   vt.trailingActive = false;

   vt.lastUpdate = TimeCurrent();

   TargetsArray.Add(vt);

   DrawTPLine(ticket, tp);

   if (EnableVirtualSL) DrawSLLine(ticket, sl);

}

**🔁**** 3.4. ManageTP_SL()**

Boucle principale exécutée à chaque OnTick(), qui :

- Vérifie si TP atteint → ferme l’ordre

- Vérifie SL (si activé)

- Gère trailing TP si activé

void ManageTP_SL() {

   for (int i = TargetsArray.Total() - 1; i >= 0; i--) {

      VirtualTarget *vt = (VirtualTarget*)TargetsArray.At(i);

      ulong ticket = vt.ticket;

      if (!OrderSelect(ticket)) continue;

      double price = SymbolInfoDouble(_Symbol, (OrderType(ticket) == ORDER_TYPE_BUY) ? SYMBOL_BID : SYMBOL_ASK);

      // TP atteint

      if ((OrderType(ticket) == ORDER_TYPE_BUY && price >= vt.price_tp) ||

          (OrderType(ticket) == ORDER_TYPE_SELL && price <= vt.price_tp)) {

         OrderClose(ticket);

         DeleteTPLine(ticket);

         TargetsArray.Remove(i);

         continue;

      }

      // SL atteint

      if (EnableVirtualSL &&

         ((OrderType(ticket) == ORDER_TYPE_BUY && price <= vt.price_sl) ||

          (OrderType(ticket) == ORDER_TYPE_SELL && price >= vt.price_sl))) {

         OrderClose(ticket);

         DeleteSLLine(ticket);

         TargetsArray.Remove(i);

         continue;

      }

      // Trailing TP

      if (EnableTrailingTP) {

         double atr = iATR(_Symbol, PERIOD_CURRENT, 14, 0);

         double newTP = (OrderType(ticket) == ORDER_TYPE_BUY) ? price + atr * TP_Trail_ATR_Mult : price - atr * TP_Trail_ATR_Mult;

         if ((OrderType(ticket) == ORDER_TYPE_BUY && newTP > vt.price_tp) ||

             (OrderType(ticket) == ORDER_TYPE_SELL && newTP < vt.price_tp)) {

            vt.price_tp = newTP;

            vt.lastUpdate = TimeCurrent();

            DrawTPLine(ticket, newTP); // Update graphique

         }

      }

   }

}

**🔂**** 3.5. Overlap TP**

void CheckTPOverlap() {

   if (!UseTPOverlap || TargetsArray.Total() < OverlapAfterXOrders) return;

   double meanTP = 0;

   int count = 0;

   for (int i = 0; i < TargetsArray.Total(); i++) {

      VirtualTarget *vt = (VirtualTarget*)TargetsArray.At(i);

      meanTP += vt.price_tp;

      count++;

   }

   meanTP /= count;

   for (int i = 0; i < TargetsArray.Total(); i++) {

      VirtualTarget *vt = (VirtualTarget*)TargetsArray.At(i);

      vt.price_tp = meanTP;

      DrawTPLine(vt.ticket, meanTP);

   }

}

**👁️**** 4. FONCTIONS GRAPHIQUES TP / SL**

void DrawTPLine(ulong ticket, double price) {

   string name = "TPLine_" + (string)ticket;

   ObjectCreate(0, name, OBJ_HLINE, 0, 0, price);

   ObjectSetInteger(0, name, OBJPROP_COLOR, TPColor);

   ObjectSetInteger(0, name, OBJPROP_WIDTH, 1);

   ObjectSetInteger(0, name, OBJPROP_STYLE, STYLE_DASH);

}

void DrawSLLine(ulong ticket, double price) {

   string name = "SLLine_" + (string)ticket;

   ObjectCreate(0, name, OBJ_HLINE, 0, 0, price);

   ObjectSetInteger(0, name, OBJPROP_COLOR, SLColor);

   ObjectSetInteger(0, name, OBJPROP_WIDTH, 1);

   ObjectSetInteger(0, name, OBJPROP_STYLE, STYLE_DOT);

}

void DeleteTPLine(ulong ticket) {

   ObjectDelete(0, "TPLine_" + (string)ticket);

}

void DeleteSLLine(ulong ticket) {

   ObjectDelete(0, "SLLine_" + (string)ticket);

}

**🧠**** 5. UTILISATION DANS OnTick() DU EA PRINCIPAL**

// Après ouverture d’un ordre

AssignTP_SL(ticket);

// À chaque tick

ManageTP_SL();

CheckTPOverlap(); // si actif

