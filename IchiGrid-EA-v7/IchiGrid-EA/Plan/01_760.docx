input bool EnableClusterZones = true;

input int ClusteringLookback = 50;

input ENUM_TIMEFRAMES ClusteringTF = PERIOD_M15;

input int ClusteringRefreshMinutes = 30;

input int MinSymbolsPerCluster = 3;

input double MinClusterCohesion = 0.85;

