  if (!CheckProtection()) return;

  if (!CheckIchimokuSignals()) return;

  if (!CanOpenNewOrder()) return;

  if (NeedToOpenGrid()) ExecuteGrid();

  ManageTP_SL();

  UpdateDashboard();

}

