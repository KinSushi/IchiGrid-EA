   return;

if (PostSignalState == STATE_IDLE && SignalFusion.SignalScore > MinFusionScore)

{

   PostSignalState = STATE_WAITING_VALIDATION;

   LastSignalTime = TimeCurrent();

   // Attente confirmation PA, SR, Cluster

}

