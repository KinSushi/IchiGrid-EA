**🔁**** 412.10. Intégration dans OnTick()**

if (EnableDecisionArbitrator) {

   ArbitrationResult arb = ResolveDecision(fusion);

   if (!arb.AllowTrade) {

      Print("❌ Décision bloquée : ", arb.BlockReason);

      return;

   }

   if (arb.ExecutionType == EXEC_FULL) OpenGrid(fusion.Bias, BaseLot);

   else if (arb.ExecutionType == EXEC_REDUCED) OpenGrid(fusion.Bias, arb.AdjustedLot);

}

