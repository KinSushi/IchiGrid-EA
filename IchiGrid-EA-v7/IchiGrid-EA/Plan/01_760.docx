input bool EnableMultiStrategyPlanGeneration = true;

input int MaxLinkedStrategiesPerPlan = 4;

input double MinRotationScoreToLink = 0.7;

input double MinFallbackReadinessPF = 0.6;

input bool AllowFallbackAutoExecution = true;

