  },

  "tracking_window": "2025-05-15 to 2025-05-26"

}

**⚙****️**** 551.3. Paramètres de contrôle**

input bool EnableExperimentalClones = true;

input bool AutoGenerateCloneOnEmergent = true;

input int MaxActiveClones = 2;

input ENUM_CLONE_MODE CloneActivationMode = CLONE_SEMI_VIRTUAL;

input bool LimitCloneToSymbol = true;

input double CloneRiskLimitPercent = 0.5;

